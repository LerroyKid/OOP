<Window x:Class="ChatApp.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в чат" Height="400" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Онлайн чат" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <TextBlock Grid.Row="1" Text="Email:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" x:Name="EmailTextBox" Margin="0,25,0,10" Padding="5"/>

        <TextBlock Grid.Row="2" Text="Пароль:" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="2" x:Name="PasswordBox" Margin="0,25,0,10" Padding="5"/>

        <Button Grid.Row="3" x:Name="LoginButton" Content="Войти" Click="LoginButton_Click" 
                Margin="0,10,0,5" Padding="10" Background="#007ACC" Foreground="White"/>
        
        <Button Grid.Row="4" x:Name="RegisterButton" Content="Регистрация" Click="RegisterButton_Click" 
                Margin="0,5,0,5" Padding="10"/>
        
        <StackPanel Grid.Row="5" x:Name="LoadingPanel" Visibility="Collapsed" 
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="⏳ Подключение..." FontSize="14" Foreground="#007ACC"/>
        </StackPanel>
    </Grid>
</Window>
