<Window x:Class="ChatApp.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: контакты -->
        <Grid Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10">
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Профиль" FontSize="16" FontWeight="Bold" 
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Content="⚙️" Click="SettingsButton_Click" 
                            Width="35" Height="35" FontSize="18" 
                            ToolTip="Настройки" Background="Transparent" 
                            BorderThickness="0" HorizontalAlignment="Right"/>
                </Grid>
                
                <!-- Аватар -->
                <Border Width="60" Height="60" BorderBrush="#007ACC" BorderThickness="2" 
                        CornerRadius="30" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Border.Clip>
                        <EllipseGeometry Center="30,30" RadiusX="28" RadiusY="28"/>
                    </Border.Clip>
                    <Grid>
                        <Image x:Name="ProfileAvatarImage" Stretch="UniformToFill"/>
                        <TextBlock x:Name="ProfileAvatarPlaceholder" Text="👤" FontSize="35" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#999"/>
                    </Grid>
                </Border>
                
                <TextBlock x:Name="UsernameText" Text="Пользователь" Margin="0,0,0,5" 
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="StatusComboBox" Margin="0,5,0,0" SelectionChanged="StatusComboBox_SelectionChanged">
                    <ComboBoxItem Content="Онлайн" IsSelected="True"/>
                    <ComboBoxItem Content="Не беспокоить"/>
                    <ComboBoxItem Content="Офлайн"/>
                </ComboBox>
                <Button Content="Редактировать профиль" Margin="0,10,0,0" Click="EditProfileButton_Click" Padding="5"/>
                <Button Content="🚪 Выйти" Margin="0,5,0,0" Click="LogoutButton_Click" 
                        Padding="5" Background="#DC3545" Foreground="White"/>
            </StackPanel>

            <TextBox Grid.Row="1" x:Name="SearchBox" Margin="10" Padding="5" 
                     Text="Поиск контактов..." GotFocus="SearchBox_GotFocus" TextChanged="SearchBox_TextChanged"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="10,0,10,10">
                <ListBox x:Name="ContactsListBox" BorderThickness="0" Background="Transparent"
                         SelectionChanged="ContactsListBox_SelectionChanged"/>
            </ScrollViewer>
        </Grid>

        <!-- Правая панель: чат -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#007ACC" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <!-- Аватар собеседника -->
                    <Border Width="40" Height="40" BorderBrush="White" BorderThickness="2" 
                            CornerRadius="20" Margin="0,0,10,0">
                        <Border.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="18" RadiusY="18"/>
                        </Border.Clip>
                        <Grid>
                            <Image x:Name="ContactAvatarImage" Stretch="UniformToFill"/>
                            <TextBlock x:Name="ContactAvatarPlaceholder" Text="👤" FontSize="25" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Grid>
                    </Border>
                    
                    <TextBlock x:Name="ChatHeaderText" Text="Выберите контакт" 
                               Foreground="White" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MessagesPanel" Margin="10"/>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="MessageTextBox" Padding="5" 
                         VerticalAlignment="Center" KeyDown="MessageTextBox_KeyDown"/>
                <Button Grid.Column="1" Content="📎" Width="40" Margin="5,0" 
                        Click="AttachButton_Click"/>
                <Button Grid.Column="2" Content="Отправить" Padding="10,5" 
                        Click="SendButton_Click" Background="#007ACC" Foreground="White"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
