<Window x:Class="ChatApp.Client.Views.ViewProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль пользователя" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Аватар -->
            <Border Width="120" Height="120" BorderBrush="#007ACC" BorderThickness="3" 
                    CornerRadius="60" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Border.Clip>
                    <EllipseGeometry Center="60,60" RadiusX="57" RadiusY="57"/>
                </Border.Clip>
                <Grid>
                    <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
                    <TextBlock x:Name="AvatarPlaceholder" Text="👤" FontSize="70" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#999"/>
                </Grid>
            </Border>

            <!-- Имя пользователя -->
            <TextBlock Text="Имя пользователя" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox" Padding="8" Margin="0,0,0,15" IsReadOnly="True" 
                     Background="#F5F5F5" BorderBrush="#CCC"/>

            <!-- Email -->
            <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailTextBox" Padding="8" Margin="0,0,0,15" IsReadOnly="True"
                     Background="#F5F5F5" BorderBrush="#CCC"/>

            <!-- Статус -->
            <TextBlock Text="Статус" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Ellipse x:Name="StatusIndicator" Width="16" Height="16" 
                         Fill="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="StatusTextBlock" Text="Офлайн" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- О себе -->
            <TextBlock Text="О себе" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="BioTextBox" Padding="8" Height="100" TextWrapping="Wrap" 
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                     Margin="0,0,0,15" IsReadOnly="True" Background="#F5F5F5" BorderBrush="#CCC"/>

            <!-- ID пользователя -->
            <TextBlock x:Name="UserIdText" Text="ID: " FontSize="10" Foreground="Gray" 
                       HorizontalAlignment="Center" Margin="0,10,0,15"/>

            <!-- Кнопка закрыть -->
            <Button Content="Закрыть" Padding="15,8" Click="CloseButton_Click" 
                    Background="#007ACC" Foreground="White" FontSize="14"/>
        </StackPanel>
    </ScrollViewer>
</Window>
