<Window x:Class="ChatApp.Client.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="350" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#007ACC" Padding="15">
            <TextBlock Text="⚙️ Настройки" FontSize="20" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30">
            <StackPanel>
                <!-- Настройки уведомлений -->
                <TextBlock Text="Уведомления" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <CheckBox x:Name="SoundNotificationsCheckBox" Content="🔔 Звуковые уведомления" 
                          Margin="0,0,0,10" IsChecked="True" FontSize="14"/>
                
                <CheckBox x:Name="BannerNotificationsCheckBox" Content="📢 Показывать баннеры" 
                          Margin="0,0,0,10" IsChecked="True" FontSize="14"/>
                
                <CheckBox x:Name="SmartNotificationsCheckBox" 
                          Content="🧠 Умные уведомления" 
                          Margin="0,0,0,5" IsChecked="True" FontSize="14"/>
                <TextBlock Text="Не показывать уведомления в активном диалоге" 
                           FontSize="11" Foreground="#666" Margin="25,0,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки внизу -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 Сохранить" Click="SaveButton_Click" 
                        Padding="25,10" Margin="0,0,10,0" Background="#007ACC" 
                        Foreground="White" FontWeight="Bold" FontSize="14"/>
                <Button Content="✖ Отмена" Click="CancelButton_Click" 
                        Padding="25,10" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
