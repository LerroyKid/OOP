<Window x:Class="ChatApp.Client.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена пароля" Height="400" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#007ACC" Padding="15">
            <TextBlock Text="🔒 Смена пароля" FontSize="20" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Прокручиваемое содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Текущий пароль:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="CurrentPasswordBox" Padding="8" FontSize="14"/>
                    <TextBlock Text="Введите ваш текущий пароль для подтверждения" 
                               FontSize="11" Foreground="#999" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Новый пароль:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NewPasswordBox" Padding="8" FontSize="14"/>
                    <TextBlock Text="Минимум 6 символов" 
                               FontSize="11" Foreground="#999" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Подтвердите новый пароль:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Padding="8" FontSize="14"/>
                    <TextBlock Text="Повторите новый пароль" 
                               FontSize="11" Foreground="#999" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки внизу -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🔒 Изменить пароль" Click="ChangeButton_Click" 
                        Padding="25,10" Margin="0,0,10,0" Background="#007ACC" 
                        Foreground="White" FontWeight="Bold" FontSize="14"/>
                <Button Content="✖ Отмена" Click="CancelButton_Click" 
                        Padding="25,10" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
