@echo off
chcp 65001 >nul
echo ═══════════════════════════════════════════════════════════════
echo   ОСТАНОВКА СЕРВЕРА ChatApp
echo ═══════════════════════════════════════════════════════════════
echo.

echo Поиск процесса на порту 56188...
echo.

set found=0
for /f "tokens=5" %%a in ('netstat -ano ^| findstr :56188') do (
    set found=1
    echo Найден процесс: %%a
    taskkill /PID %%a /F >nul 2>&1
    if errorlevel 1 (
        echo ❌ Не удалось остановить процесс %%a
        echo    Попробуйте запустить от имени администратора
    ) else (
        echo ✓ Процесс %%a успешно остановлен
    )
)

if %found%==0 (
    echo ℹ️  Сервер не запущен (порт 56188 свободен)
)

echo.
echo ═══════════════════════════════════════════════════════════════
echo   ГОТОВО
echo ═══════════════════════════════════════════════════════════════
echo.
pause
