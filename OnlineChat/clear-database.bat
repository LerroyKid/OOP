@echo off
chcp 65001 >nul
echo ═══════════════════════════════════════════════════════════════
echo   ОЧИСТКА БАЗЫ ДАННЫХ (удаление всех аккаунтов и сообщений)
echo ═══════════════════════════════════════════════════════════════
echo.
echo ⚠️  ВНИМАНИЕ! Это удалит:
echo   • Все аккаунты пользователей
echo   • Всю историю сообщений
echo   • Все загруженные файлы останутся
echo.
pause
echo.

echo [1/3] Остановка сервера...
taskkill /F /IM ChatApp.Server.exe 2>nul
timeout /t 2 /nobreak >nul

echo [2/3] Удаление базы данных...
del ChatApp.Server\chatapp.db 2>nul
if exist ChatApp.Server\chatapp.db (
    echo ❌ Не удалось удалить базу данных
    echo    Закройте все программы использующие базу
    pause
    exit /b 1
)
echo ✓ База данных удалена

echo [3/3] Создание новой базы данных...
cd ChatApp.Server
dotnet ef database update

echo.
echo ═══════════════════════════════════════════════════════════════
echo   ✅ ГОТОВО! База данных очищена
echo ═══════════════════════════════════════════════════════════════
echo.
echo Теперь можно запустить сервер и создать новые аккаунты
echo.
pause
