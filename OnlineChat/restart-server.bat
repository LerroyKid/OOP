@echo off
chcp 65001 >nul
echo ═══════════════════════════════════════════════════════════════
echo   ПЕРЕЗАПУСК СЕРВЕРА ChatApp
echo ═══════════════════════════════════════════════════════════════
echo.

echo [1/3] Остановка старого процесса на порту 56188...
for /f "tokens=5" %%a in ('netstat -ano ^| findstr :56188') do (
    echo Найден процесс: %%a
    taskkill /PID %%a /F >nul 2>&1
    if errorlevel 1 (
        echo ⚠️  Не удалось остановить процесс %%a
    ) else (
        echo ✓ Процесс %%a остановлен
    )
)

echo.
echo [2/3] Ожидание освобождения порта...
timeout /t 2 /nobreak >nul

echo.
echo [3/3] Запуск сервера...
cd ChatApp.Server
echo.
echo ═══════════════════════════════════════════════════════════════
echo   СЕРВЕР ЗАПУЩЕН
echo ═══════════════════════════════════════════════════════════════
echo.
echo Для остановки нажмите Ctrl+C
echo.
dotnet run
